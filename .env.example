# SonicGraph Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env files — they are gitignored

# =============================================================================
# Firebase (Phase 5)
# =============================================================================
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=

# =============================================================================
# MusicBrainz API (Phase 3)
# =============================================================================
# Required: User-Agent header for MusicBrainz API compliance
# Format: AppName/Version (ContactEmail)
MUSICBRAINZ_USER_AGENT=SonicGraph/1.0 (your-email@example.com)

# =============================================================================
# Wikidata (Phase 4)
# =============================================================================
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# =============================================================================
# App Configuration
# =============================================================================
APP_ENV=dev
